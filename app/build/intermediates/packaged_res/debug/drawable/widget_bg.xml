<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/widget_background" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="#22FFFFFF" />
        </shape>
    </item>
    <!-- Top highlight using an inset stroke trick -->
    <item android:bottom="4dp" android:left="0dp" android:right="0dp" android:top="0dp">
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="16dp" android:topRightRadius="16dp" />
            <!-- We'll use a very faint gradient fading down to simulate top highlight -->
            <gradient
                android:startColor="#1AFFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
        </shape>
    </item>
</layer-list>

<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:padding="14dp">

    <!-- Header: label + dark-mode toggle + add button -->
    <RelativeLayout
        android:id="@+id/widget_header_row"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:layout_alignParentTop="true">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="UPCOMING"
            android:textColor="@color/widget_text_secondary"
            android:textSize="10sp"
            android:textStyle="bold" />

        <!-- Dark mode toggle -->
        <ImageView
            android:id="@+id/widget_btn_dark_toggle"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_toStartOf="@+id/widget_btn_add"
            android:layout_marginEnd="6dp"
            android:layout_centerVertical="true"
            android:background="@drawable/widget_icon_btn_bg"
            android:contentDescription="Toggle dark mode"
            android:padding="6dp"
            android:src="@drawable/ic_widget_moon" />

        <!-- Add button -->
        <ImageView
            android:id="@+id/widget_btn_add"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/widget_icon_btn_bg"
            android:contentDescription="Add Task"
            android:padding="6dp"
            android:src="@drawable/ic_widget_add" />
    </RelativeLayout>

    <!-- Footer: dot + time + done button -->
    <RelativeLayout
        android:id="@+id/widget_footer_row"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_alignParentBottom="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@+id/widget_btn_done"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingEnd="8dp">

            <ImageView
                android:id="@+id/widget_task_dot"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_marginEnd="6dp"
                android:src="@drawable/ic_widget_dot_normal" />

            <TextView
                android:id="@+id/widget_task_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/widget_text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/widget_btn_done"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/widget_done_btn_bg"
            android:contentDescription="Done"
            android:padding="7dp"
            android:src="@drawable/ic_widget_check"
            android:tint="@color/widget_accent"
            android:visibility="gone" />
    </RelativeLayout>

    <!-- Task name: fills space between header and footer -->
    <TextView
        android:id="@+id/widget_task_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_header_row"
        android:layout_above="@id/widget_footer_row"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        android:text="No active tasks"
        android:textColor="@color/widget_text_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="end"
        android:gravity="center_vertical" />

</RelativeLayout>

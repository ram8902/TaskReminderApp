<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container_list"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg">

    <!-- Header: label + dark mode toggle + add button -->
    <RelativeLayout
        android:id="@+id/widget_header"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_alignParentTop="true"
        android:paddingStart="16dp"
        android:paddingEnd="10dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:text="MY TASKS"
            android:textColor="@color/widget_text_primary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <!-- Add button -->
        <ImageView
            android:id="@+id/widget_btn_add"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/widget_icon_btn_bg"
            android:contentDescription="Add Task"
            android:padding="6dp"
            android:src="@drawable/ic_widget_add"
            android:tint="@color/widget_accent" />

        <!-- Dark mode toggle -->
        <ImageView
            android:id="@+id/widget_btn_dark_toggle"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_toStartOf="@id/widget_btn_add"
            android:layout_marginEnd="6dp"
            android:layout_centerVertical="true"
            android:background="@drawable/widget_icon_btn_bg"
            android:contentDescription="Toggle dark mode"
            android:padding="6dp"
            android:src="@drawable/ic_widget_moon" />
    </RelativeLayout>

    <!-- Hairline divider -->
    <FrameLayout
        android:id="@+id/widget_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/widget_header"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:background="@color/widget_divider" />


    <!-- Task list -->
    <ListView
        android:id="@+id/widget_list_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/widget_divider"
        android:layout_alignParentBottom="true"
        android:divider="@color/widget_divider"
        android:dividerHeight="1dp" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/widget_empty_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/widget_divider"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All done!"
            android:textColor="@color/widget_text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Enjoy your day"
            android:textColor="@color/widget_text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

</RelativeLayout>

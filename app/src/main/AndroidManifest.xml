<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions for notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Alarm permissions -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <application
        android:name=".TaskReminderApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ic_launcher_new"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher_new"
        android:supportsRtl="true"
        android:theme="@style/Theme.TaskReminderApp"
        tools:targetApi="31">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.TaskReminderApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Full-screen alarm activity shown over the lock screen -->
        <activity
            android:name=".AlarmActivity"
            android:exported="false"
            android:launchMode="singleInstance"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:theme="@style/Theme.TaskReminderApp" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.TaskReminderApp" />

        <!-- Confirm task completion dialog launched from widgets -->
        <activity
            android:name=".ConfirmTaskActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleInstance"
            android:taskAffinity=""
            android:theme="@style/Theme.TaskReminderApp.QuickAdd" />

        <!-- Floating activity over home screen for quick task creation -->
        <activity
            android:name=".QuickAddActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:windowSoftInputMode="stateVisible|adjustResize"
            android:theme="@style/Theme.TaskReminderApp.QuickAdd" />

        <!-- Widgets -->
        <receiver
            android:name=".widget.SingleTaskWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/single_task_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.TaskListWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/task_list_widget_info" />
        </receiver>

        <service
            android:name=".widget.TaskListWidgetService"
            android:permission="android.permission.BIND_REMOTEVIEWS" />

        <receiver
            android:name=".widget.WidgetActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.taskreminder.widget.ACTION_MARK_TASK_DONE" />
                <action android:name="com.example.taskreminder.widget.ACTION_TOGGLE_DARK_MODE" />
            </intent-filter>
        </receiver>

        <!-- AlarmReceiver — fires exact alarms and reschedules the next one -->
        <receiver
            android:name=".worker.AlarmReceiver"
            android:exported="false" />

        <!-- BootReceiver — reschedules alarms after device reboot -->
        <receiver
            android:name=".worker.BootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- WorkManager Boot receiver is automatically added by work-runtime -->
    </application>

</manifest>

